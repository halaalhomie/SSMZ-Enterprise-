# App
DEBUG=false
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql://storeims:changeme@localhost:5432/storeims
DATABASE_URL_ASYNC=postgresql+asyncpg://storeims:changeme@localhost:5432/storeims

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=storeims-uploads
S3_BUCKET_BACKUPS=storeims-backups
CLOUDFRONT_DOMAIN=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
